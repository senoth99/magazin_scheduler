# Shop Scheduler — шаблон для production (скопируйте в .env на сервере)

NODE_ENV=production
TZ=Europe/Moscow

APP_URL=https://your-domain.example
DATABASE_URL=file:/data/app/shop.db
UPLOADS_DIR=/data/app/uploads

SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
SESSION_COOKIE_SECURE=true

TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_USERNAME=solo9905
TELEGRAM_ADMIN_TELEGRAM_ID=
NEXT_PUBLIC_TELEGRAM_CONTACT=

NEXT_PUBLIC_TELEGRAM_AUTH_DEV=false
TELEGRAM_ALLOW_DEV_LOGIN=false

# Опционально: метка билда на странице входа
# NEXT_PUBLIC_BUILD_REF=

# PORT=3000
