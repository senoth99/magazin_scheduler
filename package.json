{
  "name": "shop-scheduler",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "setup:local": "prisma generate && prisma db push",
    "dev": "TZ=Europe/Moscow NODE_ENV=development WATCHPACK_POLLING=true next dev",
    "dev:3099": "TZ=Europe/Moscow NODE_ENV=development WATCHPACK_POLLING=true next dev --hostname 127.0.0.1 --port 3099",
    "dev:turbo": "TZ=Europe/Moscow NODE_ENV=development WATCHPACK_POLLING=true next dev --turbo",
    "dev:fresh": "prisma generate && prisma db push && TZ=Europe/Moscow NODE_ENV=development WATCHPACK_POLLING=true next dev",
    "dev:reset": "rm -rf .next && TZ=Europe/Moscow NODE_ENV=development WATCHPACK_POLLING=true next dev",
    "build": "prisma generate && TZ=Europe/Moscow next build",
    "start": "TZ=Europe/Moscow next start",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "predeploy": "prisma generate && npm run lint && rm -rf .next && npm run build",
    "deploy:check": "npm run predeploy && npx prisma migrate diff --from-migrations prisma/migrations --to-schema-datamodel prisma/schema.prisma --exit-code"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "html5-qrcode": "^2.3.8",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "^15.0.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^15.5.15",
    "@types/node": "^22.9.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "postcss": "^8.4.49",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1"
  },
  "description": "Shop Scheduler — смены и отчёты по торговым точкам: сотрудники выбирают точку, ставят смены, отмечают приход и сдают отчёты; админы управляют точками, доступом и графиком.",
  "main": "postcss.config.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
