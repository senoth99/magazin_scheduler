# Shop Scheduler — смены и отчёты по торговым точкам (магазинам).
# Локально (без Postgres): файл рядом с schema.prisma
DATABASE_URL=file:./dev.db
# Фото отчётов (вне public, переживает деплой). Локально по умолчанию prisma/uploads; на VPS: file:/data/app/production.db → /data/app/uploads
# UPLOADS_DIR=/data/app/uploads
# После git clone или смены schema: npm install && npm run db:push && npm run prisma:seed
# Один раз всё поднять: npm run dev:fresh
# Схема обязательна (http:// или https://). Вариант «localhost:3000» без схемы ломал редиректы /api/login/token → 500.
APP_URL=http://localhost:3000
# Короткий git SHA, подставляется в deploy.sh перед `npm run build` — на /telegram/login видно, какой билд отдал сервер.
# Вручную: export NEXT_PUBLIC_BUILD_REF=$(git rev-parse --short HEAD) && npm run build
# NEXT_PUBLIC_BUILD_REF=
SESSION_SECRET=change_me_super_long_random_secret
# Для локального входа по http://127.0.0.1 или http://192.168.x.x (без HTTPS) оставьте false или явно HTTPS в APP_URL
SESSION_COOKIE_SECURE=false

# Telegram (Mini App initData + вход из обычного браузера через бота)
# 1) BotFather → /newbot → TELEGRAM_BOT_TOKEN
# 2) NEXT_PUBLIC_TELEGRAM_BOT_USERNAME — username бота без @
# 3) TELEGRAM_WEBHOOK_SECRET — произвольная длинная строка (secret_token в setWebhook)
# 4) Webhook: https://ВАШ_ДОМЕН/api/telegram/webhook (см. README или инструкцию в чате)
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Резервный super-admin без строки в allowlist: совпадение @username ИЛИ числового id Telegram (удобно, если в TG нет @username)
TELEGRAM_ADMIN_USERNAME=
TELEGRAM_ADMIN_TELEGRAM_ID=
# Опционально: другой контакт только для страницы «нет доступа» (виден клиенту)
NEXT_PUBLIC_TELEGRAM_CONTACT=

# Production: при true десктоп без сессии → /access-denied. Оставьте false, чтобы входить с ПК через /telegram/login и бота.
# AUTH_DESKTOP_NO_SESSION_ACCESS_DENIED=false

# --- Локальный вход БЕЗ бота (только development) ---
NEXT_PUBLIC_TELEGRAM_AUTH_DEV=true
TELEGRAM_ALLOW_DEV_LOGIN=true
# Виртуальный Telegram-профиль для сессии dev (не ходит в Telegram API):
TELEGRAM_DEV_TELEGRAM_ID=918273645
TELEGRAM_DEV_USERNAME=
TELEGRAM_DEV_FIRST_NAME=Локальная
TELEGRAM_DEV_LAST_NAME=сессия
# SUPER_ADMIN | ADMIN | EMPLOYEE (по умолчанию SUPER_ADMIN)
TELEGRAM_DEV_ROLE=SUPER_ADMIN

# Если в базе нет пользователей с ролью EMPLOYEE и нужны тестовые строки не в режиме development:
# MANAGER_DEMO_USERS_ON_EMPTY=1

# ---------------------------------------------------------------------------
# Production — полная инструкция: DEPLOY.md, шаблон: .env.production.example
# ---------------------------------------------------------------------------
# ./deploy.sh на сервере (PM2: shop-scheduler)
# DATABASE_URL=file:/data/app/shop.db  UPLOADS_DIR=/data/app/uploads
# APP_URL=https://your-domain.example  SESSION_COOKIE_SECURE=true
# NEXT_PUBLIC_TELEGRAM_AUTH_DEV=false  TELEGRAM_ALLOW_DEV_LOGIN=false
